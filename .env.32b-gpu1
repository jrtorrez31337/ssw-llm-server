# SSW AI — Qwen3-32B-AWQ, GPU 1 only (GPU 0 free)
PRIMARY_MODEL=Qwen/Qwen3-32B-AWQ
PRIMARY_GPU_MEMORY_UTILIZATION=0.90
PRIMARY_DTYPE=half
PRIMARY_QUANTIZATION=awq_marlin

VLLM_MAX_MODEL_LEN=49152
VLLM_MAX_NUM_SEQS=32
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_TOOL_CALL_PARSER=hermes

MODEL_REPO=/data/models
MODEL_0_PORT=8001
GATEWAY_PORT=8000
LOADER_PORT=8011
REDIS_PORT=6379

LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw
